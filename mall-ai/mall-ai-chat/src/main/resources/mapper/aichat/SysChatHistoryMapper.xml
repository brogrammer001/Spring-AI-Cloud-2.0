<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mall.aichat.mapper.SysChatHistoryMapper">
    
    <resultMap type="SysChatHistory" id="SysChatHistoryResult">
        <result property="conversationId"    column="conversation_id"    />
        <result property="content"    column="content"    />
        <result property="type"    column="type"    />
        <result property="timestamp"    column="timestamp"    />
        <result property="sequenceId"    column="sequence_id"    />
        <result property="userName"    column="user_name"    />
        <result property="isCompression"    column="is_compression"    />
    </resultMap>

    <sql id="selectSysChatHistoryVo">
        select id, conversation_id, content, type, timestamp, sequence_id, is_compression from sys_chat_history t1
    </sql>

    <select id="selectSysChatHistoryList" parameterType="SysChatHistory" resultMap="SysChatHistoryResult">
        SELECT
        t1.id,
        t1.conversation_id,
        content,
        type,
        TIMESTAMP,
        sequence_id,
        is_compression,
        u.user_name
        FROM
        sys_chat_history t1
        LEFT JOIN ai_conversation t2 ON t1.conversation_id = t2.conversation_id
        LEFT JOIN `mall-system`.sys_user u ON t2.user_id = u.user_id
        <where>
            AND t1.type &lt;&gt; 'COMPRESS'
            <if test="conversationId != null  and conversationId != ''"> and t1.conversation_id = #{conversationId}</if>
            <if test="content != null  and content != ''"> and t1.content = #{content}</if>
            <if test="type != null  and type != ''"> and t1.type = #{type}</if>
            <if test="timestamp != null "> and t1.timestamp = #{timestamp}</if>
            <if test="sequenceId != null "> and t1.sequence_id = #{sequenceId}</if>
            <if test="isCompression != null "> and t1.is_compression = #{isCompression}</if>
        </where>
        order by t1.sequence_id asc
    </select>
    
    <select id="selectSysChatHistoryById" parameterType="String" resultMap="SysChatHistoryResult">
        SELECT
        t1.id,
        t1.conversation_id,
        content,
        type,
        TIMESTAMP,
        sequence_id,
        is_compression,
        u.user_name
        FROM
        sys_chat_history t1
        LEFT JOIN ai_conversation t2 ON t1.conversation_id = t2.conversation_id
        LEFT JOIN `mall-system`.sys_user u ON t2.user_id = u.user_id
        where t1.id = #{id} AND t1.type &lt;&gt; 'COMPRESS'
        order by sequence_id asc
    </select>

    <select id="selectSysChatHistoryByConversationId" parameterType="String" resultMap="SysChatHistoryResult">
        <include refid="selectSysChatHistoryVo"/>
        where conversation_id = #{conversationId}
        AND t1.type &lt;&gt; 'COMPRESS'
        order by sequence_id asc
    </select>

    <select id="selectSysChatHistoryListAll" parameterType="SysChatHistory" resultMap="SysChatHistoryResult">
        <include refid="selectSysChatHistoryVo"/>
        <where>
            <if test="conversationId != null  and conversationId != ''"> and t1.conversation_id = #{conversationId}</if>
            <if test="content != null  and content != ''"> and t1.content = #{content}</if>
            <if test="type != null  and type != ''"> and t1.type = #{type}</if>
            <if test="timestamp != null "> and t1.timestamp = #{timestamp}</if>
            <if test="sequenceId != null "> and t1.sequence_id = #{sequenceId}</if>
            <if test="isCompression != null "> and t1.is_compression = #{isCompression}</if>
        </where>
    </select>

    <insert id="insertSysChatHistory" parameterType="SysChatHistory">
        insert into sys_chat_history
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="conversationId != null and conversationId != ''">conversation_id,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="type != null and type != ''">type,</if>
            <if test="timestamp != null">timestamp,</if>
            <if test="sequenceId != null">sequence_id,</if>
            <if test="isCompression != null">is_compression,</if>
            <if test="id != null">id,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="conversationId != null and conversationId != ''">#{conversationId},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="type != null and type != ''">#{type},</if>
            <if test="timestamp != null">#{timestamp},</if>
            <if test="sequenceId != null">#{sequenceId},</if>
            <if test="isCompression != null">#{isCompression},</if>
            <if test="id != null">#{id},</if>
         </trim>
    </insert>

    <update id="updateSysChatHistory" parameterType="SysChatHistory">
        update sys_chat_history
        <trim prefix="SET" suffixOverrides=",">
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="type != null and type != ''">type = #{type},</if>
            <if test="timestamp != null">timestamp = #{timestamp},</if>
            <if test="sequenceId != null">sequence_id = #{sequenceId},</if>
            <if test="isCompression != null">is_compression = #{isCompression},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteSysChatHistoryByConversationId" parameterType="String">
        delete from sys_chat_history where conversation_id = #{conversationId}
    </delete>

    <delete id="deleteSysChatHistoryById" parameterType="String">
        delete from sys_chat_history where id = #{id}
    </delete>

    <delete id="deleteSysChatHistoryByConversationIds" parameterType="String">
        delete from sys_chat_history where conversation_id in 
        <foreach item="conversationId" collection="array" open="(" separator="," close=")">
            #{conversationId}
        </foreach>
    </delete>
</mapper>
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mall.aichat.mapper.KbDocumentChunkMapper">
    
    <resultMap type="KbDocumentChunk" id="KbDocumentChunkResult">
        <result property="id"    column="id"    />
        <result property="documentId"    column="document_id"    />
        <result property="knowledgeId"    column="knowledge_id"    />
        <result property="content"    column="content"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectKbDocumentChunkVo">
        select id, document_id, knowledge_id, content, create_time from kb_document_chunk
    </sql>

    <select id="selectKbDocumentChunkList" parameterType="KbDocumentChunk" resultMap="KbDocumentChunkResult">
        <include refid="selectKbDocumentChunkVo"/>
        <where>  
            <if test="documentId != null  and documentId != ''"> and document_id = #{documentId}</if>
            <if test="knowledgeId != null  and knowledgeId != ''"> and knowledge_id = #{knowledgeId}</if>
            <if test="content != null  and content != ''"> and content = #{content}</if>
        </where>
    </select>
    
    <select id="selectKbDocumentChunkById" parameterType="String" resultMap="KbDocumentChunkResult">
        <include refid="selectKbDocumentChunkVo"/>
        where id = #{id}
    </select>

    <insert id="insertKbDocumentChunk" parameterType="KbDocumentChunk">
        insert into kb_document_chunk
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="documentId != null and documentId != ''">document_id,</if>
            <if test="knowledgeId != null and knowledgeId != ''">knowledge_id,</if>
            <if test="content != null">content,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="documentId != null and documentId != ''">#{documentId},</if>
            <if test="knowledgeId != null and knowledgeId != ''">#{knowledgeId},</if>
            <if test="content != null">#{content},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateKbDocumentChunk" parameterType="KbDocumentChunk">
        update kb_document_chunk
        <trim prefix="SET" suffixOverrides=",">
            <if test="documentId != null and documentId != ''">document_id = #{documentId},</if>
            <if test="knowledgeId != null and knowledgeId != ''">knowledge_id = #{knowledgeId},</if>
            <if test="content != null">content = #{content},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteKbDocumentChunkById" parameterType="String">
        delete from kb_document_chunk where id = #{id}
    </delete>

    <delete id="deleteKbDocumentChunkByIds" parameterType="String">
        delete from kb_document_chunk where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteKbDocumentChunkByKnowledgeIds" parameterType="String">
        delete from kb_document_chunk where knowledge_id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>